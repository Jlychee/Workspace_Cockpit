<Window x:Class="Workspace_Cockpit.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Workspace Cockpit"
        Width="1120"
        Height="760"
        MinWidth="940"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0D1117"
        Foreground="#C9D1D9"
        FontFamily="Segoe UI">

    <!-- Темный стиль для всех ToolTip (подсказок при наведении) -->
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1D2430" />
            <Setter Property="Foreground" Value="#C9D1D9" />
            <Setter Property="BorderBrush" Value="#30363D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>


    <Border Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Border Grid.Row="0"
                    Background="#0D1117"
                    BorderBrush="{StaticResource Line2Brush}"
                    BorderThickness="0,0,0,1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left app title -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">

                        <TextBlock Text="⬡"
                                   Foreground="{StaticResource BlueBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="0,0,8,0" />

                        <TextBlock Text="Workspace Cockpit"
                                   Foreground="{StaticResource BlueBrush}"
                                   FontSize="13"
                                   FontWeight="Bold" />
                    </StackPanel>

                    <!-- Right window controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch">

                        <Button Content="─"
                                Style="{StaticResource TitleBarButton}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="Minimize_Click" />

                        <Button Content="□"
                                Style="{StaticResource TitleBarButton}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="Maximize_Click" />

                        <Button Content="×"
                                Style="{StaticResource CloseTitleBarButton}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                FontSize="18"
                                Click="Close_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- App content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="#121821"
                        BorderBrush="{StaticResource Line2Brush}"
                        BorderThickness="0,0,1,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0"
                                Padding="16"
                                BorderBrush="{StaticResource Line2Brush}"
                                BorderThickness="0,0,0,1">

                            <Grid>
                                <TextBox x:Name="WorkspaceSearchTextBox"
                                         Padding="10,7" />

                                <TextBlock Text="Поиск workspace..."
                                           Margin="21,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Muted2Brush}"
                                           FontSize="13"
                                           IsHitTestVisible="False">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />

                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Text.Length, ElementName=WorkspaceSearchTextBox}"
                                                    Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Workspace list -->
                        <ListBox Grid.Row="1"
                                 Padding="8,10"
                                 ItemsSource="{Binding Workspaces}"
                                 SelectedItem="{Binding SelectedWorkspace}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding Meta}"
                                                   Margin="0,3,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource Muted2Brush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>


                        </ListBox>

                        <!-- Sidebar footer -->
                        <Border Grid.Row="2"
                                Padding="12"
                                BorderBrush="{StaticResource Line2Brush}"
                                BorderThickness="0,1,0,0">
                            <Button Content="+ New workspace"
                                    Click="NewWorkspace_Click" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Main -->
                <Grid Grid.Column="1">
                    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="22">
                            <!-- Workspace header -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Отступ Margin="0,0,24,0", чтобы не липло к кнопкам -->
                                <Grid Grid.Column="0" Margin="0,0,24,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" 
                                               Text="{Binding SelectedWorkspace.Name}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" 
                                               Text="{Binding SelectedWorkspace.RootPath}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{StaticResource Muted2Brush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               ToolTip="{Binding SelectedWorkspace.RootPath}" />

                                    <TextBlock Grid.Row="2" 
                                               Text="{Binding SelectedWorkspace.DetailsText}"
                                               Margin="0,5,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource Muted2Brush}" />
                                </Grid>

                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top">

                                    <Button Content="▶ Run all"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,0"
                                            Click="RunAllActions_Click" />

                                    <Button Content="Edit" />
                                </WrapPanel>
                            </Grid>

                            <!-- Resume block -->
                            <Border Background="{StaticResource Panel2Brush}"
                                    BorderBrush="{StaticResource Line2Brush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,18">

                                <Grid>
                                    <Border Width="3"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource BlueBrush}"
                                            CornerRadius="8,0,0,8" />

                                    <StackPanel Margin="14">
                                        <TextBlock Text="Где я остановился"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Muted2Brush}"
                                                   TextOptions.TextFormattingMode="Display"
                                                   Margin="0,0,0,8" />

                                        <TextBox MinHeight="78"
                                            FontSize="14"
                                            TextWrapping="Wrap"
                                            AcceptsReturn="True"
                                            VerticalScrollBarVisibility="Auto"
                                            Text="{Binding SelectedWorkspace.ResumeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SelectedWorkspace.UpdatedText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource Muted2Brush}"
                                                       VerticalAlignment="Center" />

                                            <Button Grid.Column="1"
                                                    Content="Save resume"
                                                    Click="SaveResume_Click" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>


                            <TabControl Style="{StaticResource CockpitTabControl}">

                                <!-- Actions tab -->
                                <TabItem Header="Actions">
                                    <Border Style="{StaticResource PanelBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="42" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <!-- Actions toolbar -->
                                            <Border Grid.Row="0"
                                                    Background="#1D2430"
                                                    BorderBrush="{StaticResource Line2Brush}"
                                                    BorderThickness="0,0,0,1"
                                                    CornerRadius="8,8,0,0">

                                                <Grid Margin="14,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Actions"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">

                                                        <Button Content="Add"
                                                                Margin="0,0,8,0"
                                                                Click="AddAction_Click" />

                                                        <Button Content="Edit"
                                                                Margin="0,0,8,0"
                                                                Click="EditAction_Click" />

                                                        <Button Content="Delete"
                                                                Style="{StaticResource DangerButton}"
                                                                Margin="0,0,8,0"
                                                                Click="DeleteAction_Click" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Actions list -->
                                            <ListBox Grid.Row="1"
                                                     Margin="14,12"
                                                     ItemsSource="{Binding SelectedWorkspace.Actions}"
                                                     SelectedItem="{Binding SelectedAction}"
                                                     PreviewMouseWheel="ListBox_PreviewMouseWheel"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8">
                                                            <Border Background="{StaticResource Panel2Brush}"
                                                                    BorderBrush="{StaticResource Line2Brush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10,9">

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <!-- Отступ Margin="0,0,16,0", чтобы не липло к кнопке Run -->
                                                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                FontSize="13"
                                                                                FontWeight="SemiBold" />

                                                                            <TextBlock Text="{Binding ActionType}"
                                                                                Margin="10,1,0,0"
                                                                                Style="{StaticResource ActionTypeLabel}" />
                                                                        </StackPanel>

                                                                        <TextBlock Text="{Binding Target}"
                                                                            Margin="0,2,0,0"
                                                                            FontFamily="Consolas"
                                                                            FontSize="12"
                                                                            Foreground="{StaticResource MutedBrush}"
                                                                            TextTrimming="CharacterEllipsis"
                                                                            TextWrapping="NoWrap"
                                                                            ToolTip="{Binding Target}" />

                                                                        <TextBlock Text="{Binding LastRunText}"
                                                                            Margin="0,3,0,0"
                                                                            FontSize="11"
                                                                            Foreground="{StaticResource Muted2Brush}"
                                                                            TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>

                                                                    <Button Grid.Column="1"
                                                                            Content="Run"
                                                                            VerticalAlignment="Center"
                                                                            Tag="{Binding}"
                                                                            Click="RunAction_Click" />
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </TabItem>

                                <!-- Notes tab -->
                                <TabItem Header="Notes">
                                    <Border Style="{StaticResource PanelBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="42" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <!-- Notes toolbar -->
                                            <Border Grid.Row="0"
                                                    Background="#1D2430"
                                                    BorderBrush="{StaticResource Line2Brush}"
                                                    BorderThickness="0,0,0,1"
                                                    CornerRadius="8,8,0,0">

                                                <Grid Margin="14,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Notes"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">

                                                        <Button Content="Add note"
                                                                Margin="0,0,8,0"
                                                                Click="AddNote_Click" />

                                                        <Button Content="Edit"
                                                                Margin="0,0,8,0"
                                                                Click="EditNote_Click" />

                                                        <Button Content="Delete"
                                                                Style="{StaticResource DangerButton}"
                                                                Click="DeleteNote_Click" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Notes list -->
                                            <ListBox Grid.Row="1"
                                                     Margin="14,12"
                                                     ItemsSource="{Binding SelectedWorkspace.Notes}"
                                                     SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                                                     PreviewMouseWheel="ListBox_PreviewMouseWheel"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8">
                                                            <Border Background="{StaticResource Panel2Brush}"
                                                                    BorderBrush="{StaticResource Line2Brush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10">

                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal"
                                                                        Margin="0,0,0,5">
                                                                        <TextBlock Text="{Binding Type}"
                                                                            Style="{StaticResource NoteTypeLabel}" />

                                                                        <TextBlock Text="{Binding UpdatedText}"
                                                                            Margin="8,0,0,0"
                                                                            Foreground="{StaticResource Muted2Brush}"
                                                                            FontSize="12"
                                                                            FontWeight="SemiBold" />
                                                                    </StackPanel>

                                                                    <TextBlock Text="{Binding Text}"
                                                                               FontSize="13"
                                                                               TextWrapping="Wrap"
                                                                               LineHeight="20" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </TabItem>

                                <!-- Logs tab -->
                                <TabItem Header="Logs">
                                    <Border Style="{StaticResource PanelBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="42" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <!-- Logs toolbar -->
                                            <Border Grid.Row="0"
                                                    Background="#1D2430"
                                                    BorderBrush="{StaticResource Line2Brush}"
                                                    BorderThickness="0,0,0,1"
                                                    CornerRadius="8,8,0,0">

                                                <Grid Margin="14,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Logs"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">

                                                        <Button Content="Clear"
                                                                Margin="0,0,8,0"
                                                                Click="ClearLog_Click" />

                                                        <Button Content="Remove selected"
                                                                Click="RemoveSelectedLog_Click" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Log list -->
                                            <ListBox Grid.Row="1"
                                                     x:Name="LogList"
                                                     ItemsSource="{Binding ActionRuns}"
                                                     SelectedItem="{Binding SelectedActionRun}"
                                                     PreviewMouseWheel="ListBox_PreviewMouseWheel"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource Panel2Brush}"
                                                                BorderBrush="{StaticResource Line2Brush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <!-- Отступ Margin="0,0,16,0", чтобы не липло к статусу -->
                                                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                                        <TextBlock Text="{Binding ActionNameSnapshot}"
                                                                            FontSize="13"
                                                                            FontWeight="SemiBold" />

                                                                        <TextBlock Text="{Binding TargetSnapshot}"
                                                                            Margin="0,2,0,0"
                                                                            FontFamily="Consolas"
                                                                            FontSize="12"
                                                                            Foreground="{StaticResource MutedBrush}"
                                                                            TextTrimming="CharacterEllipsis"
                                                                            TextWrapping="NoWrap"
                                                                            ToolTip="{Binding TargetSnapshot}" />
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Status}"
                                                                               Foreground="{StaticResource BlueBrush}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Margin="12,0,0,0" />
                                                                </Grid>

                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,6,0,0">
                                                                    <TextBlock Text="{Binding StartedText}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource Muted2Brush}" />

                                                                    <TextBlock Text="{Binding DurationText}"
                                                                               Margin="12,0,0,0"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource Muted2Brush}" />

                                                                    <TextBlock Text="{Binding ExitCodeText}"
                                                                               Margin="12,0,0,0"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource Muted2Brush}" />
                                                                </StackPanel>

                                                                <TextBlock Text="{Binding ErrorMessage}"
                                                                           Margin="0,6,0,0"
                                                                           Foreground="{StaticResource RedBrush}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="420">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="Не выбрана рабочая область"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />

                            <TextBlock
                                Text="Создай workspace или выбери его в sidebar, чтобы открыть заметки, действия и лог запусков."
                                Margin="0,8,0,0"
                                FontSize="13"
                                Foreground="{StaticResource MutedBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>