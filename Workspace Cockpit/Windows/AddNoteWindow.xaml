<Window x:Class="Workspace_Cockpit.AddNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add note"
        Width="440"
        Height="340"
        MinWidth="440"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            Padding="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Новая заметка"
                           FontSize="18"
                           FontWeight="Bold" />

                <TextBlock Text="Запиши мысль, напоминание или текущий контекст по workspace."
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Label -->
            <TextBlock Grid.Row="2"
                       Text="Текст заметки"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}" />

            <!-- Text input -->
            <TextBox x:Name="NoteTextBox"
                     Grid.Row="4"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top" />

            <!-- Buttons -->
            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Cancel"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />

                <Button Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>